# Appium & Device Configurations
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
AUTOMATION_NAME=UiAutomator2
DRIVER_TYPE=UiAutomator2
DEVICE_NAME=Android_Emulator
PLATFORM_VERSION=14.0

# APK Settings
APK_PATH=../arogya-ai-release.apk
APP_PACKAGE=com.arogya.ai.arogya_ai
APP_ACTIVITY=.MainActivity

# Test Data Defaults
TEST_USER_EMAIL=testuser@arogya.ai
TEST_USER_PASSWORD=Password@123
INVALID_USER_EMAIL=invalid.user@arogya.ai
INVALID_USER_PASSWORD=WrongPassword123

# Reporting & Logging
LOG_LEVEL=info
CAPTURE_SCREENSHOT_ON_SUCCESS=false
ENABLE_AI_DISCOVERY=true
