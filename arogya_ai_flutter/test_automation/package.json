{
  "name": "arogya-ai-flutter-e2e-automation",
  "version": "1.0.0",
  "description": "Production-grade E2E mobile automation framework for Arogya AI Flutter Android App using Appium 2.x, Mocha, Chai, ExcelJS, Winston, and GitHub Actions",
  "main": "src/driver/driverFactory.js",
  "scripts": {
    "test": "mocha --config .mocharc.json test/specs/**/*.spec.js",
    "test:auth": "mocha --config .mocharc.json test/specs/auth.spec.js",
    "test:form": "mocha --config .mocharc.json test/specs/formValidation.spec.js",
    "test:ui": "mocha --config .mocharc.json test/specs/uiComponents.spec.js",
    "test:gestures": "mocha --config .mocharc.json test/specs/gestures.spec.js",
    "test:nav": "mocha --config .mocharc.json test/specs/navigation.spec.js",
    "test:ai": "mocha --config .mocharc.json test/specs/aiAssisted.spec.js",
    "test:e2e": "mocha --config .mocharc.json test/specs/endToEndApp.spec.js",
    "report:excel": "node -e \"require('./src/utils/excelReporter').generateSampleReport()\""
  },
  "keywords": [
    "appium",
    "flutter",
    "android",
    "e2e",
    "automation",
    "mocha",
    "chai",
    "exceljs",
    "winston",
    "mochawesome"
  ],
  "author": "Arogya AI QA Architecture Team",
  "license": "ISC",
  "dependencies": {
    "appium": "^2.11.2",
    "chai": "^4.3.10",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "mocha": "^10.4.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "webdriverio": "^8.38.0",
    "winston": "^3.13.0"
  }
}
